{
  "name": "cogniquest",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma de ensino gamificada. Primeiro jogo: Batalha Naval PvP.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @cogniquest/db generate",
    "db:migrate": "pnpm --filter @cogniquest/db migrate",
    "db:seed": "pnpm --filter @cogniquest/db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0"
  }
}
