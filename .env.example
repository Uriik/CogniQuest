# ==== CogniQuest — variáveis de ambiente (exemplo) ====
# Copie para .env (NUNCA commite .env). Em produção use GCP Secret Manager.

# --- PostgreSQL (Cloud SQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/cogniquest"

# --- Redis (Cloud Memorystore) ---
REDIS_URL="redis://localhost:6379"

# --- Auth.js (NextAuth) ---
AUTH_SECRET="troque-isto-por-um-segredo-forte"
AUTH_URL="http://localhost:3000"
JWT_ACCESS_TTL="900"        # segundos (15 min)
JWT_REFRESH_TTL="2592000"   # segundos (30 dias)

# --- Convites (HMAC) ---
INVITE_SIGNING_SECRET="troque-isto"

# --- Cloudflare Turnstile (CAPTCHA) ---
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- SMTP (e-mails transacionais: verificação, convite) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@cogniquest.com"

# --- Game server ---
GAME_SERVER_PORT="4000"
GAME_SERVER_ORIGIN="http://localhost:3000"
